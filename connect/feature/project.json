{
  "name": "libs-connect-feature",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "connect/feature/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["type:feature", "domain:connect"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-connect-feature\""
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../coverage/connect/feature"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
