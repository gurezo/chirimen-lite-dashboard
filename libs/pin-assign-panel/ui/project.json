{
  "name": "libs-pin-assign-panel-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/pin-assign-panel/ui/src",
  "projectType": "library",
  "tags": ["type:ui", "domain:pin-assign-panel"],
  "implicitDependencies": ["libs-dialogs-util", "libs-ui"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-pin-assign-panel-ui\""
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "libs/pin-assign-panel/ui/**/*.ts",
          "libs/pin-assign-panel/ui/**/*.html"
        ]
      }
    }
  }
}
