{
  "name": "libs-wifi-data-access",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/wifi/data-access/src",
  "projectType": "library",
  "tags": ["type:data-access", "domain:wifi"],
  "implicitDependencies": ["libs-wifi-util", "libs-web-serial-data-access"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-wifi-data-access\""
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/wifi/data-access/**/*.ts"]
      }
    }
  }
}
