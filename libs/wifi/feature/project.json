{
  "name": "libs-wifi-feature",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/wifi/feature/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["type:feature", "domain:wifi"],
  "implicitDependencies": [
    "libs-wifi-ui",
    "libs-wifi-data-access",
    "libs-wifi-util",
    "libs-dialogs-util",
    "libs-shared-ui"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-wifi-feature\""
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/wifi/feature/**/*.ts"]
      }
    }
  }
}
