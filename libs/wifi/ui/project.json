{
  "name": "libs-wifi-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/wifi/ui/src",
  "projectType": "library",
  "tags": ["type:ui", "domain:wifi"],
  "implicitDependencies": ["libs-wifi-util", "libs-shared-ui"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-wifi-ui\""
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/wifi/ui/**/*.ts"]
      }
    }
  }
}
