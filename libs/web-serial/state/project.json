{
  "name": "libs-web-serial-state",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/web-serial/state/src",
  "projectType": "library",
  "tags": ["type:state", "domain:web-serial"],
  "implicitDependencies": ["libs-web-serial-util", "libs-web-serial-data-access"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-web-serial-state\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/web-serial/state/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/web-serial/state/**/*.ts"]
      }
    }
  }
}
