{
  "name": "libs-terminal-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/terminal/ui/src",
  "projectType": "library",
  "tags": ["type:ui", "domain:terminal"],
  "implicitDependencies": ["libs-terminal-util", "libs-web-serial-data-access"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-terminal-ui\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/terminal/ui/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/terminal/ui/**/*.ts", "libs/terminal/ui/**/*.html"]
      }
    }
  }
}
