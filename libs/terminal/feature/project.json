{
  "name": "libs-terminal-feature",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/terminal/feature/src",
  "prefix": "choh",
  "projectType": "library",
  "tags": ["type:feature", "domain:terminal"],
  "implicitDependencies": ["libs-terminal-ui", "libs-terminal-util", "libs-dialogs-feature", "libs-web-serial"],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-terminal-feature\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/terminal/feature/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
