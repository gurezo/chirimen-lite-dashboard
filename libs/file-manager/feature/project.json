{
  "name": "libs-file-manager-feature",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/file-manager/feature/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [
    "type:feature",
    "domain:file-manager"
  ],
  "implicitDependencies": ["libs-web-serial-state"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "command": "echo \"build libs-file-manager-feature\""
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "{projectRoot}/../../../coverage/libs/file-manager/feature"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
