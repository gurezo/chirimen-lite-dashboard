{
  "name": "libs-dialogs-util",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/dialogs/util/src",
  "projectType": "library",
  "tags": [
    "type:util",
    "domain:dialogs"
  ],
  "targets": {
    "prepare-package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/generate-lib-package.js {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "dependsOn": ["^build", "prepare-package"],
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/dialogs/util/ng-package.json",
        "tsConfig": "libs/dialogs/util/tsconfig.lib.json"
      },
      "configurations": {
        "production": {},
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/dialogs/util/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/dialogs/util/**/*.ts"]
      }
    }
  }
}
