{
  "name": "libs-dialogs-feature",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/dialogs/feature/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["type:feature", "domain:dialogs"],
  "implicitDependencies": ["libs-dialogs-util", "libs-dialogs-ui"],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-dialogs-feature\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/dialogs/feature/vite.config.mts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
