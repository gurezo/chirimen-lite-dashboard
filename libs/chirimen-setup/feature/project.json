{
  "name": "libs-chirimen-setup-feature",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/chirimen-setup/feature/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [
    "type:feature",
    "domain:chirimen-setup"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "command": "echo \"build libs-chirimen-setup-feature\""
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "{projectRoot}/../../../coverage/libs/chirimen-setup/feature"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
