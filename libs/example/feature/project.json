{
  "name": "libs-example-feature",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/example/feature/src",
  "prefix": "choh",
  "projectType": "library",
  "tags": ["type:feature", "domain:example"],
  "implicitDependencies": [
    "libs-example-ui",
    "libs-example-data-access",
    "libs-dialogs-feature",
    "libs-ui"
  ],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-example-feature\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/example/feature/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/example/feature/**/*.ts"]
      }
    }
  }
}
