      "@libs-console-guards": ["libs/shared/guards/src/index.ts"],
      "@libs-chirimen-panel": ["libs/chirimen-panel/src/index.ts"],
      "@libs-connect-feature": ["libs/connect/feature/src/index.ts"],
      "@libs-connect-ui": ["libs/connect/ui/src/index.ts"],
      "@libs-connect-util": ["libs/connect/util/src/index.ts"],
      "@libs-console-shell-feature": ["libs/console-shell/feature/src/index.ts"],
      "@libs-console-shell-ui": ["libs/console-shell/ui/src/index.ts"],
      "@libs-console-shell-util": ["libs/console-shell/util/src/index.ts"],
      "@libs-dialogs-feature": ["libs/dialogs/feature/src/index.ts"],
      "@libs-dialogs-ui": ["libs/dialogs/ui/src/index.ts"],
      "@libs-dialogs-util": ["libs/dialogs/util/src/index.ts"],
      "@libs-editor": ["libs/editor/src/index.ts"],
      "@libs-editor-data-access": ["libs/editor/data-access/src/index.ts"],
      "@libs-editor-ui": ["libs/editor/ui/src/index.ts"],
      "@libs-editor-util": ["libs/editor/util/src/index.ts"],
