      "@libs-file-manager-data-access": [
        "libs/file-manager/data-access/src/index.ts"
      ],
      "@libs-file-manager-feature": ["libs/file-manager/feature/src/index.ts"],
      "@libs-file-manager-ui": ["libs/file-manager/ui/src/index.ts"],
      "@libs-file-manager-util": ["libs/file-manager/util/src/index.ts"],
      "@libs-i2cdetect-data-access": [
        "libs/i2cdetect/data-access/src/index.ts"
      ],
      "@libs-i2cdetect-ui": ["libs/i2cdetect/ui/src/index.ts"],
      "@libs-i2cdetect-util": ["libs/i2cdetect/util/src/index.ts"],
      "@libs-page-not-found": ["libs/page-not-found/src/index.ts"],
      "@libs-remote-data-access": [
        "libs/remote/data-access/src/index.ts"
      ],
      "@libs-remote-feature": ["libs/remote/feature/src/index.ts"],
      "@libs-remote-ui": ["libs/remote/ui/src/index.ts"],
      "@libs-remote-util": ["libs/remote/util/src/index.ts"],
