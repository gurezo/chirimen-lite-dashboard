        "libs/setup/data-access/src/index.ts"
      ],
      "@libs-setup-feature": ["libs/setup/feature/src/index.ts"],
      "@libs-setup-ui": ["libs/setup/ui/src/index.ts"],
      "@libs-setup-util": ["libs/setup/util/src/index.ts"],
      "@libs-shared-types": ["libs/shared/types/src/index.ts"],
      "@libs-shared-util": ["libs/shared/util/src/index.ts"],
      "@libs-terminal-feature": ["libs/terminal/feature/src/index.ts"],
      "@libs-terminal-ui": ["libs/terminal/ui/src/index.ts"],
      "@libs-terminal-util": ["libs/terminal/util/src/index.ts"],
      "@libs-ui": ["libs/shared/ui/src/index.ts"],
