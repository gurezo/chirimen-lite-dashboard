{
  "compileOnSave": false,
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom", "dom.iterable"],
    "typeRoots": ["node_modules/@types", "@types/jest"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["apps/dashboard/src/app/*"],
      "@dashboard/guards": ["libs/shared/guards/src/index.ts"],
      "@libs-chirimen-panel": ["libs/chirimen-panel/src/index.ts"],
      "@libs-dialogs": ["libs/dialogs/src/index.ts"],
      "@libs-editor": ["libs/editor/src/index.ts"],
      "@libs-console": ["libs/console/src/index.ts"],
      "@libs-example": ["libs/example/src/index.ts"],
      "@libs-i2cdetect": ["libs/i2cdetect/src/index.ts"],
      "@libs-shared": ["libs/shared/ui/src/index.ts"],
      "@libs-ui": ["libs/shared/ui/src/index.ts"],
      "@libs-web-serial": ["libs/web-serial/src/index.ts"],
      "@libs-wifi": ["libs/wifi/src/index.ts"],
      "@libs-xterm": ["libs/xterm/src/index.ts"],
      "@libs-page-not-found": ["libs/page-not-found/src/index.ts"],
      "@libs-unsupported-browser": ["libs/unsupported-browser/src/index.ts"]
    }
  }
}
